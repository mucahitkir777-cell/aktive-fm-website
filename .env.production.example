# ========================================
# PRODUCTION ENVIRONMENT - MINIMAL CONFIG
# ========================================
# This file contains only the REQUIRED and STRONGLY RECOMMENDED variables
# for a production-ready deployment.
#
# For additional optional integrations, see .env.tracking.example
#
# Code References:
# - Blocking at Startup: DATABASE_URL
# - Blocking at Login: ADMIN_JWT_SECRET (if no valid token provided)
# - Blocking at Bootstrap: ADMIN_PASSWORD (only if no users exist in DB)
# - Optional but Recommended: All others

# ========================================
# A. REQUIRED FOR PRODUCTION STARTUP
# ========================================

# Database Connection (BLOCKING: required for server startup)
# Schema: postgresql://user:password@host:port/database
# Generated with: createdb proclean_db && pg_restore -d proclean_db backup.sql
DATABASE_URL=postgresql://user:password@localhost:5432/proclean_db

# Database SSL (RECOMMENDED for production)
# Set to "require" for PostgreSQL over SSL, "disable" for unencrypted (not recommended for production)
DATABASE_SSL=require

# Node Environment (CRITICAL: must be "production" for security hardening)
# If not set to "production": Dev fallbacks are used (weak security defaults)
NODE_ENV=production

# Admin Authentication Secret (BLOCKING: required for admin login and session verification)
# Used to sign/verify JWT tokens. If empty in production: admin login will fail.
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=your_secure_jwt_secret_min_32_chars_here

# Admin Bootstrap Password (BLOCKING only if no users exist in DB)
# Used only during first startup to create initial admin user.
# Once admin user exists in database, this variable is no longer needed.
# If you already have users in DB, this can be left empty or removed.
ADMIN_PASSWORD=your_secure_admin_password_here

# ========================================
# B. STRONGLY RECOMMENDED (SEO & Analytics)
# ========================================

# Site URL for Canonical URLs and Meta Tags (SEO CRITICAL)
# Falls back to hardcoded "https://aktive-fm.de" if not set.
# MUST be your actual production domain for correct SEO canonical links.
VITE_SITE_URL=https://www.aktive-fm.de

# Google Analytics 4 Measurement ID (HIGHLY RECOMMENDED)
# Format: G-XXXXXXXXXX
# If not set: GA4 tracking is disabled
# Get from: https://analytics.google.com/ → Admin → Measurement ID
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console Verification (RECOMMENDED)
# Required to verify domain ownership in Google Search Console
# Falls back to placeholder if not set (verification won't work)
VITE_GOOGLE_SITE_VERIFICATION=your_google_verification_token_here

# ========================================
# C. OPTIONAL EMAIL DELIVERY (if needed)
# ========================================

# Master Email Switch
# Set to "true" to enable email notifications and confirmations
# If "false": all email delivery is skipped, but leads are still stored in database
LEAD_EMAIL_ENABLED=false

# Email Feature Flags (only active if LEAD_EMAIL_ENABLED=true)
# LEAD_EMAIL_NOTIFICATION_ENABLED: Send notification email to your team
# LEAD_EMAIL_CONFIRMATION_ENABLED: Send confirmation email to the lead
LEAD_EMAIL_NOTIFICATION_ENABLED=false
LEAD_EMAIL_CONFIRMATION_ENABLED=false

# Brevo Transactional Email API (only needed if LEAD_EMAIL_ENABLED=true)
BREVO_API_KEY=your-brevo-api-key
LEAD_EMAIL_FROM=info@aktive-fm.de
LEAD_NOTIFICATION_TO=info@aktive-fm.de

# ========================================
# D. OPTIONAL INTEGRATIONS
# ========================================

# Local Lead Inbox (optional backup storage)
# If enabled: leads are also written to LEAD_INBOX_FILE
# If disabled (default): leads only go to database
LEAD_INBOX_ENABLED=false
LEAD_INBOX_FILE=./data/leads.jsonl

# Webhook Integration (optional third-party delivery)
LEAD_WEBHOOK_ENABLED=false
LEAD_WEBHOOK_ENDPOINT=https://hooks.example.com/proclean-leads

# CRM Integration (optional)
LEAD_CRM_ENABLED=false
LEAD_CRM_ENDPOINT=https://crm.example.com/leads
LEAD_CRM_PROVIDER=placeholder

# Tracking Integrations (optional)
VITE_GA4_ENABLED=true
VITE_GA4_DEBUG=false
VITE_GTM_ENABLED=false
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX
VITE_UMAMI_ENABLED=false
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=
VITE_HEATMAP_ENABLED=false
VITE_HEATMAP_PROVIDER=placeholder
VITE_HEATMAP_PROJECT_ID=
VITE_CRM_TRACKING_ENABLED=false
VITE_CRM_LEAD_ENDPOINT=

# ========================================
# E. INTERNAL DEFAULTS (no change needed)
# ========================================

VITE_TRACKING_DEBUG=false
VITE_LEAD_API_ENDPOINT=/api/leads
ADMIN_USERNAME=admin
ADMIN_SESSION_TTL_SECONDS=28800
PORT=3000
