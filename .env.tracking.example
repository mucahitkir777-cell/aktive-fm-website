VITE_TRACKING_DEBUG=true

VITE_GA4_ENABLED=true
VITE_GA4_MEASUREMENT_ID=G-RM3SBZCP0G
VITE_GA4_DEBUG=true

VITE_GTM_ENABLED=false
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

VITE_UMAMI_ENABLED=false
VITE_UMAMI_WEBSITE_ID=UMAMI-WEBSITE-ID
VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js

VITE_HEATMAP_ENABLED=false
VITE_HEATMAP_PROVIDER=placeholder
VITE_HEATMAP_PROJECT_ID=YOUR_HEATMAP_PROJECT_ID

VITE_CRM_TRACKING_ENABLED=false
VITE_CRM_LEAD_ENDPOINT=https://crm.example.com/leads
VITE_CRM_PROVIDER=placeholder

VITE_LEAD_API_ENDPOINT=/api/leads
VITE_LEAD_WEBHOOK_ENABLED=false
VITE_LEAD_WEBHOOK_ENDPOINT=https://hooks.example.com/proclean-leads
VITE_LEAD_CRM_ENABLED=false
VITE_LEAD_CRM_ENDPOINT=https://crm.example.com/leads
VITE_LEAD_CRM_PROVIDER=placeholder
VITE_LEAD_EMAIL_ENABLED=false
VITE_LEAD_EMAIL_ENDPOINT=https://email.example.com/send-lead
VITE_LEAD_EMAIL_PROVIDER=placeholder

# Server-side Lead Configuration
# LEAD_INBOX_ENABLED: Default is false. If enabled, leads are also written to a local JSONL file.
LEAD_INBOX_ENABLED=false
LEAD_INBOX_FILE=./data/leads.jsonl
LEAD_WEBHOOK_ENABLED=false
LEAD_WEBHOOK_ENDPOINT=https://hooks.example.com/proclean-leads
LEAD_CRM_ENABLED=false
LEAD_CRM_ENDPOINT=https://crm.example.com/leads
LEAD_CRM_PROVIDER=placeholder
# Email Configuration
# LEAD_EMAIL_ENABLED: Master switch. If false, all email delivery is skipped.
# LEAD_EMAIL_NOTIFICATION_ENABLED: Team notification email (to LEAD_NOTIFICATION_TO).
# LEAD_EMAIL_CONFIRMATION_ENABLED: Customer confirmation email (to lead's email address).
# Both sub-flags require LEAD_EMAIL_ENABLED=true to be active.
LEAD_EMAIL_ENABLED=false
LEAD_EMAIL_NOTIFICATION_ENABLED=false
LEAD_EMAIL_CONFIRMATION_ENABLED=false

# SMTP Configuration (only required if LEAD_EMAIL_ENABLED=true)
LEAD_SMTP_HOST=smtp.example.com
LEAD_SMTP_PORT=587
LEAD_SMTP_SECURE=false
LEAD_SMTP_USER=notifications@example.com
LEAD_SMTP_PASSWORD=
LEAD_EMAIL_FROM=notifications@example.com
LEAD_NOTIFICATION_TO=team@example.com

# LEAD_EMAIL_ENDPOINT: Fallback webhook endpoint used only if SMTP is not fully configured.
# Not recommended for production. Leave empty or comment out if using SMTP.
LEAD_EMAIL_ENDPOINT=https://email.example.com/send-lead

# LEAD_EMAIL_PROVIDER: Not actively used in code, kept for reference only (cosmetic).
LEAD_EMAIL_PROVIDER=placeholder

# SEO & Site Configuration
# VITE_SITE_URL: Used for canonical URLs and og:url meta tags.
# If not set, falls back to hardcoded: https://aktive-fm.de
# MUST be corrected to your actual domain for production (affects SEO).
VITE_SITE_URL=https://www.proclean-gmbh.de

# VITE_GOOGLE_SITE_VERIFICATION: Google Search Console verification token.
# If not set, defaults to placeholder. Required for Search Console verification.
VITE_GOOGLE_SITE_VERIFICATION=GOOGLE_SEARCH_CONSOLE_PLACEHOLDER
